# Feishu OpenAPI credentials. Never commit real secrets.
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=replace_with_your_app_secret

# Bitable app token. It is the base/wiki bitable token, not the Open Platform App ID.
FEISHU_BITABLE_APP_TOKEN=appxxxxxxxxxxxxxxxx

# One business data type per Bitable table.
FEISHU_BITABLE_PARTICIPANTS_TABLE_ID=tblxxxxxxxxxxxxxxxx
FEISHU_BITABLE_SESSIONS_TABLE_ID=tblxxxxxxxxxxxxxxxx
FEISHU_BITABLE_DRAG_ELEMENTS_TABLE_ID=tblxxxxxxxxxxxxxxxx
FEISHU_BITABLE_INSPIRE_ELEMENTS_TABLE_ID=tblxxxxxxxxxxxxxxxx
FEISHU_BITABLE_MODE_USAGE_TABLE_ID=tblxxxxxxxxxxxxxxxx
FEISHU_BITABLE_WORK_COUNTS_TABLE_ID=tblxxxxxxxxxxxxxxxx

# Optional admin key for export/sync status endpoints.
HEALING_EXPORT_KEY=replace_with_research_admin_key

# NiceGUI user/session storage secret. Set a long random value in production.
HEALING_STORAGE_SECRET=replace_with_long_random_storage_secret

# OpenAI-compatible image editing service.
HEALING_IMAGE_API_KEY=replace_with_image_api_key
HEALING_IMAGE_API_URL=https://aihubmix.com/v1
HEALING_IMAGE_MODEL=gpt-image-2
HEALING_IMAGE_SIZE=auto
HEALING_IMAGE_QUALITY=auto
HEALING_IMAGE_OPERATION=edit
HEALING_IMAGE_EDIT_MAX_SIZE=1536
